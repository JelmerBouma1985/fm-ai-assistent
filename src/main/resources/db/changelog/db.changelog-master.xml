    <changeSet id="019-create-fm-role-attribute-tables" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="fm_role"/>
            </not>
        </preConditions>
        <createTable tableName="fm_role">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="game" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="position_group" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="role_name" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="phase" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint
                tableName="fm_role"
                columnNames="game, role_name, phase"
                constraintName="uk_fm_role"/>

        <createTable tableName="fm_attribute">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="attribute_name" type="VARCHAR(1024)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_fm_attribute"/>
            </column>
        </createTable>

        <createTable tableName="fm_role_attribute">
            <column name="role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="attribute_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="attribute_priority" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey
                tableName="fm_role_attribute"
                columnNames="role_id, attribute_id, attribute_priority"
                constraintName="pk_fm_role_attribute"/>
        <addForeignKeyConstraint
                baseTableName="fm_role_attribute"
                baseColumnNames="role_id"
                referencedTableName="fm_role"
                referencedColumnNames="id"
                constraintName="fk_fm_role_attribute_role"
                onDelete="CASCADE"/>
        <addForeignKeyConstraint
                baseTableName="fm_role_attribute"
                baseColumnNames="attribute_id"
                referencedTableName="fm_attribute"
                referencedColumnNames="id"
                constraintName="fk_fm_role_attribute_attribute"
                onDelete="CASCADE"/>
        <sql>
            ALTER TABLE fm_role_attribute
            ADD CONSTRAINT chk_fm_role_attribute_priority
            CHECK (attribute_priority IN ('primary', 'secondary'));
        </sql>

        <createTable tableName="fm_role_attribute_import">
            <column name="game" type="VARCHAR(1024)"/>
            <column name="position_group" type="VARCHAR(1024)"/>
            <column name="role_name" type="VARCHAR(1024)"/>
            <column name="phase" type="VARCHAR(1024)"/>
            <column name="attribute_priority" type="VARCHAR(32)"/>
            <column name="attribute_name" type="VARCHAR(1024)"/>
            <column name="sort_order" type="INT"/>
        </createTable>
    </changeSet>

    <changeSet id="020-load-fm-role-attribute-data" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="fm_role"/>
                <tableExists tableName="fm_attribute"/>
                <tableExists tableName="fm_role_attribute"/>
                <tableExists tableName="fm_role_attribute_import"/>
            </and>
        </preConditions>
        <delete tableName="fm_role_attribute_import"/>
        <loadData
                tableName="fm_role_attribute_import"
                file="db/data/fm26_positional_roles_attributes_flat.csv"
                separator=","
                quotchar="&quot;">
            <column header="game" name="game" type="STRING"/>
            <column header="position_group" name="position_group" type="STRING"/>
            <column header="role" name="role_name" type="STRING"/>
            <column header="phase" name="phase" type="STRING"/>
            <column header="attribute_priority" name="attribute_priority" type="STRING"/>
            <column header="attribute_name" name="attribute_name" type="STRING"/>
            <column header="sort_order" name="sort_order" type="NUMERIC"/>
        </loadData>
        <sql>
            INSERT INTO fm_role (game, position_group, role_name, phase)
            SELECT DISTINCT i.game, i.position_group, i.role_name, i.phase
            FROM fm_role_attribute_import i
            WHERE NOT EXISTS (
                SELECT 1
                FROM fm_role r
                WHERE r.game = i.game
                  AND r.role_name = i.role_name
                  AND r.phase = i.phase
            );

            INSERT INTO fm_attribute (attribute_name)
            SELECT DISTINCT i.attribute_name
            FROM fm_role_attribute_import i
            WHERE NOT EXISTS (
                SELECT 1
                FROM fm_attribute a
                WHERE a.attribute_name = i.attribute_name
            );

            INSERT INTO fm_role_attribute (role_id, attribute_id, attribute_priority, sort_order)
            SELECT r.id, a.id, i.attribute_priority, i.sort_order
            FROM fm_role_attribute_import i
            JOIN fm_role r
              ON r.game = i.game
             AND r.role_name = i.role_name
             AND r.phase = i.phase
            JOIN fm_attribute a
              ON a.attribute_name = i.attribute_name
            WHERE NOT EXISTS (
                SELECT 1
                FROM fm_role_attribute existing
                WHERE existing.role_id = r.id
                  AND existing.attribute_id = a.id
                  AND existing.attribute_priority = i.attribute_priority
            );
        </sql>
    </changeSet>

    <changeSet id="021-add-missing-hidden-player-attributes" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="players"/>
                <not>
                    <columnExists tableName="players" columnName="adaptability"/>
                </not>
            </and>
        </preConditions>
        <addColumn tableName="players">
            <column name="adaptability" type="INT"/>
            <column name="ambition" type="INT"/>
            <column name="loyalty" type="INT"/>
            <column name="pressure" type="INT"/>
            <column name="professionalism" type="INT"/>
            <column name="sportsmanship" type="INT"/>
            <column name="temperament" type="INT"/>
            <column name="controversy" type="INT"/>
        </addColumn>
    </changeSet>
