        <createTable tableName="load_metadata">
            <column name="meta_key" type="VARCHAR(100)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="meta_value" type="VARCHAR(1024)"/>
        </createTable>

        <createTable tableName="fm_role">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="game" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="position_group" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="role_name" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="phase" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="fm_attribute">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="attribute_name" type="VARCHAR(1024)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="fm_role_attribute">
            <column name="role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="attribute_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="attribute_priority" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="fm_role_attribute_import">
            <column name="game" type="VARCHAR(1024)"/>
            <column name="position_group" type="VARCHAR(1024)"/>
            <column name="role_name" type="VARCHAR(1024)"/>
            <column name="phase" type="VARCHAR(1024)"/>
            <column name="attribute_priority" type="VARCHAR(32)"/>
            <column name="attribute_name" type="VARCHAR(1024)"/>
            <column name="sort_order" type="INT"/>
        </createTable>

