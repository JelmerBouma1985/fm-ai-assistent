        <createIndex indexName="idx_clubs_competition_id" tableName="clubs">
            <column name="competition_id"/>
        </createIndex>
        <addForeignKeyConstraint
                baseTableName="clubs"
                baseColumnNames="competition_id"
                referencedTableName="competitions"
                referencedColumnNames="id"
                constraintName="fk_clubs_competition"
                onDelete="SET NULL"/>
    </changeSet>

    <changeSet id="016-empty-strings-to-null" author="codex">
        <sql>
            UPDATE players SET player_index = NULL WHERE player_index = '';
            UPDATE players SET record_address = NULL WHERE record_address = '';
            UPDATE players SET name = NULL WHERE name = '';
            UPDATE players SET gender = NULL WHERE gender = '';
            UPDATE players SET nationality = NULL WHERE nationality = '';
            UPDATE players SET club = NULL WHERE club = '';
            UPDATE players SET playing_club = NULL WHERE playing_club = '';
            UPDATE players SET loan_club = NULL WHERE loan_club = '';
            UPDATE players SET is_loaned_out = NULL WHERE is_loaned_out = '';
            UPDATE players SET contract_end_date = NULL WHERE contract_end_date = '';
            UPDATE players SET date_of_birth = NULL WHERE date_of_birth = '';
            UPDATE players SET age = NULL WHERE age = '';
            UPDATE players SET age_as_of = NULL WHERE age_as_of = '';
            UPDATE clubs SET name = NULL WHERE name = '';
            UPDATE clubs SET gender = NULL WHERE gender = '';
            UPDATE clubs SET competition = NULL WHERE competition = '';
            UPDATE clubs SET nation = NULL WHERE nation = '';
            UPDATE competitions SET name = NULL WHERE name = '';
            UPDATE competitions SET nation = NULL WHERE nation = '';
            UPDATE competitions SET gender = NULL WHERE gender = '';
            UPDATE load_metadata SET meta_value = NULL WHERE meta_value = '';
        </sql>
    </changeSet>

