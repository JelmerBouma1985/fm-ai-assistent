        <createIndex indexName="idx_clubs_nation" tableName="clubs">
            <column name="nation"/>
        </createIndex>
        <createIndex indexName="idx_clubs_competition" tableName="clubs">
            <column name="competition"/>
        </createIndex>
        <createIndex indexName="idx_clubs_gender" tableName="clubs">
            <column name="gender"/>
        </createIndex>
        <createIndex indexName="idx_clubs_competition_id" tableName="clubs">
            <column name="competition_id"/>
        </createIndex>
        <createIndex indexName="idx_clubs_source_address" tableName="clubs">
