        </createIndex>
        <createIndex indexName="idx_players_playing_club" tableName="players">
            <column name="playing_club"/>
        </createIndex>
        <createIndex indexName="idx_players_club_id" tableName="players">
            <column name="club_id"/>
        </createIndex>
        <createIndex indexName="idx_players_playing_club_id" tableName="players">
            <column name="playing_club_id"/>
        </createIndex>

        <addUniqueConstraint
                tableName="fm_role"
                columnNames="game, role_name, phase"
                constraintName="uk_fm_role"/>
        <addUniqueConstraint
                tableName="fm_attribute"
                columnNames="attribute_name"
                constraintName="uk_fm_attribute"/>
        <addPrimaryKey
                tableName="fm_role_attribute"
                columnNames="role_id, attribute_id, attribute_priority"
                constraintName="pk_fm_role_attribute"/>

        <addForeignKeyConstraint
                baseTableName="clubs"
                baseColumnNames="competition_id"
                referencedTableName="competitions"
                referencedColumnNames="id"
                constraintName="fk_clubs_competition"
                onDelete="SET NULL"/>
        <addForeignKeyConstraint
                baseTableName="players"
                baseColumnNames="club_id"
                referencedTableName="clubs"
                referencedColumnNames="id"
                constraintName="fk_players_club"
                onDelete="SET NULL"/>
        <addForeignKeyConstraint
                baseTableName="players"
                baseColumnNames="playing_club_id"
                referencedTableName="clubs"
                referencedColumnNames="id"
                constraintName="fk_players_playing_club"
                onDelete="SET NULL"/>
        <addForeignKeyConstraint
                baseTableName="fm_role_attribute"
                baseColumnNames="role_id"
                referencedTableName="fm_role"
                referencedColumnNames="id"
                constraintName="fk_fm_role_attribute_role"
                onDelete="CASCADE"/>
        <addForeignKeyConstraint
                baseTableName="fm_role_attribute"
                baseColumnNames="attribute_id"
                referencedTableName="fm_attribute"
                referencedColumnNames="id"
                constraintName="fk_fm_role_attribute_attribute"
                onDelete="CASCADE"/>

        <sql>
            ALTER TABLE fm_role_attribute
            ADD CONSTRAINT chk_fm_role_attribute_priority
            CHECK (attribute_priority IN ('primary', 'secondary'));
        </sql>
    </changeSet>

    <changeSet id="002-baseline-role-attribute-data" author="codex">
        <loadData
                tableName="fm_role_attribute_import"
                file="db/data/fm26_positional_roles_attributes_flat.csv"
                separator=","
                quotchar="&quot;">
            <column header="game" name="game" type="STRING"/>
            <column header="position_group" name="position_group" type="STRING"/>
            <column header="role" name="role_name" type="STRING"/>
            <column header="phase" name="phase" type="STRING"/>
            <column header="attribute_priority" name="attribute_priority" type="STRING"/>
            <column header="attribute_name" name="attribute_name" type="STRING"/>
            <column header="sort_order" name="sort_order" type="NUMERIC"/>
        </loadData>
        <sql>
            INSERT INTO fm_role (game, position_group, role_name, phase)
            SELECT DISTINCT i.game, i.position_group, i.role_name, i.phase
            FROM fm_role_attribute_import i;

            INSERT INTO fm_attribute (attribute_name)
            SELECT DISTINCT i.attribute_name
            FROM fm_role_attribute_import i;

            INSERT INTO fm_role_attribute (role_id, attribute_id, attribute_priority, sort_order)
            SELECT r.id, a.id, i.attribute_priority, i.sort_order
            FROM fm_role_attribute_import i
            JOIN fm_role r
              ON r.game = i.game
             AND r.role_name = i.role_name
             AND r.phase = i.phase
            JOIN fm_attribute a
              ON a.attribute_name = i.attribute_name;
        </sql>
    </changeSet>
</databaseChangeLog>
