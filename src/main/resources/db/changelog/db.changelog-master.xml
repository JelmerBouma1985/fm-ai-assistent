    <changeSet id="009-create-clubs" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="clubs"/>
            </not>
        </preConditions>
        <createTable tableName="clubs">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(1024)"/>
            <column name="competition" type="VARCHAR(1024)"/>
            <column name="reputation" type="INT"/>
            <column name="nation" type="VARCHAR(1024)"/>
            <column name="balance" type="BIGINT"/>
        </createTable>
        <createIndex indexName="idx_clubs_name" tableName="clubs">
            <column name="name"/>
        </createIndex>
        <createIndex indexName="idx_clubs_nation" tableName="clubs">
            <column name="nation"/>
        </createIndex>
        <createIndex indexName="idx_clubs_competition" tableName="clubs">
            <column name="competition"/>
        </createIndex>
    </changeSet>

    <changeSet id="010-add-club-budgets" author="codex">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="clubs"/>
                <not>
